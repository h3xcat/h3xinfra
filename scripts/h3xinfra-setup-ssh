#!/bin/bash
# Streamlined SSH setup for h3xinfra dev containers.
#
#   1. Copy the host's ~/.ssh into the container (~/.ssh is read-only from
#      the host mount at /tmp/host-ssh, so we copy + fix ownership/perms).
#   2. Stage the ansible managed-node private key from the CIFS-mounted
#      secrets share into ~/.ssh with strict 0600 perms. CIFS forces 0777
#      on the source, which openssh refuses to use directly.
#   3. Maintain a managed block in ~/.ssh/config so interactive `ssh`
#      to the h3xinfra managed nodes uses the same key, the same user,
#      and the same ControlMaster socket as ansible.
#   4. Load the ansible key into ssh-agent via `keychain` so the passphrase
#      is prompted at most once per container lifetime. Subsequent ansible
#      runs (and plain ssh invocations in any shell) reuse the unlocked
#      key plus the ControlMaster multiplexed socket.
#
# Re-running this script is safe; ssh-agent state is preserved by keychain
# across shell sessions.

set -euo pipefail
IFS=$'\n\t'

log() { echo "[h3xinfra-setup-ssh] $*"; }

# 1. Mirror host ~/.ssh into the container.
if [ -d /tmp/host-ssh ]; then
    mkdir -p ~/.ssh
    cp -r /tmp/host-ssh/. ~/.ssh
    chmod 700 ~/.ssh
    find ~/.ssh -type f -exec chmod 600 {} +
    chown -R "$(id -u):$(id -g)" ~/.ssh
fi

# 2. Stage the ansible managed-node private key locally. If the key is missing
# there's nothing for steps 3 and 4 to manage, so we exit early.
ANSIBLE_KEY_SRC="${H3XINFRA_SECRETS_DIR:-/h3xinfra/state/secrets}/ansible_ssh_privatekey"
ANSIBLE_KEY_DST="$HOME/.ssh/h3xinfra_ansible_id"
if [ ! -r "$ANSIBLE_KEY_SRC" ]; then
    log "Note: ansible private key not found at $ANSIBLE_KEY_SRC (skipping)"
    exit 0
fi
if ! cmp -s "$ANSIBLE_KEY_SRC" "$ANSIBLE_KEY_DST" 2>/dev/null; then
    install -m 0600 "$ANSIBLE_KEY_SRC" "$ANSIBLE_KEY_DST"
    log "Staged ansible private key at $ANSIBLE_KEY_DST"
fi
[ -r "${ANSIBLE_KEY_SRC}.pub" ] && install -m 0644 "${ANSIBLE_KEY_SRC}.pub" "${ANSIBLE_KEY_DST}.pub"

# 3. Maintain an Include fragment for h3xinfra managed nodes. Using SSH's
# native Include keeps re-runs simple: we just overwrite the fragment.
# Host patterns come from $H3XINFRA_SSH_HOST_PATTERNS (set per-deployment to
# match your inventory's hostnames + ansible_host IPs); the default matches
# inventory/production/hosts.yml's example values. `IdentitiesOnly yes` is
# important: with multiple keys loaded in the agent (personal + ansible),
# ssh would otherwise try them in order and risk MaxAuthTries lockouts.
SSH_HOST_PATTERNS="${H3XINFRA_SSH_HOST_PATTERNS:-node*.example.com 192.168.1.*}"
SSH_CONFIG="$HOME/.ssh/config"
SSH_FRAGMENT="$HOME/.ssh/h3xinfra-managed.conf"
SSH_INCLUDE_LINE="Include h3xinfra-managed.conf"
mkdir -p "$HOME/.ssh"
cat > "$SSH_FRAGMENT" <<EOF
# Auto-generated by h3xinfra-setup-ssh. Edits will be overwritten.
Host $SSH_HOST_PATTERNS
    User ansible
    IdentityFile $ANSIBLE_KEY_DST
    IdentitiesOnly yes
    ControlMaster auto
    ControlPersist 600s
    ControlPath /tmp/.ansible-ssh-%h-%p-%r
    ServerAliveInterval 30
    ServerAliveCountMax 3
EOF
chmod 600 "$SSH_FRAGMENT"
touch "$SSH_CONFIG"
chmod 600 "$SSH_CONFIG"
grep -qxF "$SSH_INCLUDE_LINE" "$SSH_CONFIG" || printf '\n%s\n' "$SSH_INCLUDE_LINE" >> "$SSH_CONFIG"
log "Refreshed $SSH_FRAGMENT and ensured Include in $SSH_CONFIG."

# 4. Load the key into ssh-agent via keychain. Passing the key path lets
# keychain handle the "already loaded?" check and the ssh-add itself; the
# eval ensures SSH_AUTH_SOCK is set for this script (user shells pick it
# up via the bashrc snippet installed by the Dockerfile).
if ! command -v keychain >/dev/null 2>&1; then
    log "WARNING: keychain not installed; passphrase will be prompted per ssh invocation."
    log "         Install with: sudo apt-get install -y keychain"
    exit 0
fi
if [ -t 0 ]; then
    eval "$(keychain --eval --quiet --agents ssh "$ANSIBLE_KEY_DST")"
else
    eval "$(keychain --eval --quiet --agents ssh)"
    log "No TTY available; agent started but ansible key not unlocked."
    log "Re-run this script from a shell to unlock once per container session:"
    log "    bash \"$H3XINFRA_FOLDER/scripts/h3xinfra-setup-ssh\""
fi